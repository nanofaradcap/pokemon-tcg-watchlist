# Database
# For development (SQLite)
DATABASE_URL="file:./dev.db"

# For production (PostgreSQL)
# DATABASE_URL="postgresql://username:password@localhost:5432/pokemon_tcg_watchlist"

# Scraping Configuration
SCRAPE_CONCURRENCY=2
SCRAPE_TIMEOUT_MS=12000

# TCGplayer API (optional)
ENABLE_TCGPLAYER_API=false
TCGPLAYER_PUBLIC_KEY=""
TCGPLAYER_PRIVATE_KEY=""

# Production Settings
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://cards.chencat.com"
NEXT_PUBLIC_TCGPLAYER_AFFILIATE_BASE_URL="https://partner.tcgplayer.com/c/7229328/1780961/21018"

# Puppeteer (optional override for hosted Chromium pack)
# CHROMIUM_PACK_URL="https://your-domain.com/path/to/chromium-pack.x64.tar"

# Backups
# SCHEMA_VERSION="jpNo-to-No-migration"
